# ---- Credentials (felogin) -------------------------------------------------
# USERNAME is reserved by the OS on some systems; tuc-archive reads
# USERNAME_FORUM first, then falls back to USERNAME.
USERNAME_FORUM=your_forum_login
PASSWORD=your_forum_password

# ---- Target site -----------------------------------------------------------
# Defaults already match the real TUC forum (www.tuc.gr). Override only to
# point at a different TYPO3 install; see tuc_archive/config.py:Site.
TUC_BASE_URL=https://www.tuc.gr
TUC_FORUM_ROOT=/el/to-polytechneio/nea-anakoinoseis-syzitiseis
# Leave empty: felogin is embedded in the forum root, and auth scrapes the
# form's own action URL.
TUC_LOGIN_URL=

# ---- Crawl behaviour -------------------------------------------------------
TUC_WORKERS=4
TUC_DELAY=0.5
TUC_RANDOM_WAIT=0
TUC_MAX_RETRIES=5
TUC_TIMEOUT=30
TUC_RESPECT_ROBOTS=1
TUC_USER_AGENT=tuc-archive/0.1 (+offline archival)
# Download same-origin CSS/JS/images into the archive (styled offline).
TUC_EMBED_ASSETS=1
# Keep author e-mails obfuscated (1 = decode to plaintext). Default off.
TUC_DEOBFUSCATE_EMAILS=0
# Stop after N pages (0 = unlimited). Handy for test runs.
TUC_MAX_PAGES=0

# ---- Paths -----------------------------------------------------------------
TUC_OUTPUT=./output
TUC_STATE=./output/state.yml
TUC_SNAPSHOT_EVERY=25

# ---- Distributed mode ------------------------------------------------------
# Shared secret workers send as X-Auth-Token. CHANGE THIS.
TUC_SECRET=change-me
